---
// Figure with caption. Wraps any visual (inline SVG, <img>, etc.) and adds a
// mono-style caption below.
interface Props {
  caption?: string
}
const { caption } = Astro.props as Props
---

<figure class="my-12">
  <div class="not-prose">
    <slot />
  </div>
  {caption && (
    <figcaption class="mt-3 text-center font-mono text-[11px] uppercase tracking-[0.18em] text-bone-300">
      {caption}
    </figcaption>
  )}
</figure>
