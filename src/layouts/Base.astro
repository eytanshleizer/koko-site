---
import "@/styles/global.css"
import Nav from "@/components/Nav.astro"
import Footer from "@/components/Footer.astro"

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title = "Eytan Shleizer",
  description = "Problem exploration, AI, and the shape of what's coming.",
  ogImage,
} = Astro.props as Props

const fullTitle = title === "Eytan Shleizer" ? title : `${title} — Eytan Shleizer`
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="bg-ink-0 text-bone-0 antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <!--
      Diagrams (mermaid + the generic <Diagram> component) are wrapped in a
      .diagram-frame with a fullscreen toggle. This script handles two things:
        1. Render mermaid source into SVG with a dark theme (black bg, white
           lines, white borders).
        2. Wire the .diagram-fullscreen buttons so clicking them toggles
           is-fullscreen on the parent .diagram-frame. ESC closes.
      Both run on initial load AND after Astro view-transitions.
    -->
    <script>
      // Scale-to-fit logic for embeds with a fixed design width. The
      // <Diagram naturalWidth={N}> prop sets data-natural-width on the body;
      // we set the child's intrinsic width to N px, measure its natural
      // height, then apply a transform that scales it to fit the body —
      // both in inline and fullscreen mode. ResizeObserver re-runs on
      // container resize.
      const scaleEmbed = (body: HTMLElement) => {
        const nw = parseFloat(body.getAttribute("data-natural-width") || "")
        if (!nw) return
        const child = body.firstElementChild as HTMLElement | null
        if (!child) return

        // Set the child's intrinsic dimensions; transform handles the rest.
        // flex-shrink: 0 because .diagram-body is `display: flex` — without
        // it the child would shrink to the container width and our width
        // setting wouldn't stick.
        child.style.width = nw + "px"
        child.style.flexShrink = "0"
        child.style.transformOrigin = "top left"
        // Strip any prior transform before measuring height.
        child.style.transform = "none"
        const nh = child.offsetHeight

        const frame = body.closest(".diagram-frame") as HTMLElement | null
        const isFullscreen = !!frame?.classList.contains("is-fullscreen")

        const cw = body.clientWidth
        const ch = body.clientHeight
        const scale = isFullscreen
          ? Math.min(cw / nw, ch / nh)
          : Math.min(1, cw / nw)

        const renderedW = nw * scale
        const renderedH = nh * scale
        const tx = (cw - renderedW) / 2
        const ty = isFullscreen ? (ch - renderedH) / 2 : 0

        child.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`

        if (!isFullscreen) {
          body.style.height = renderedH + "px"
        } else {
          body.style.height = ""
        }
      }

      const initDiagrams = async () => {
        // Wire fullscreen toggle for every diagram frame on the page.
        const frames = document.querySelectorAll<HTMLElement>(".diagram-frame")
        for (const frame of frames) {
          if ((frame as any).__diagramInit) continue
          ;(frame as any).__diagramInit = true
          const btn = frame.querySelector<HTMLButtonElement>(".diagram-fullscreen")
          if (btn) {
            btn.addEventListener("click", () => {
              frame.classList.toggle("is-fullscreen")
              document.body.classList.toggle(
                "diagram-overlay-open",
                frame.classList.contains("is-fullscreen"),
              )
              // Re-scale the embed inside this frame after the layout settles.
              const body = frame.querySelector<HTMLElement>(
                ".diagram-body[data-natural-width]",
              )
              if (body) requestAnimationFrame(() => scaleEmbed(body))
            })
          }
        }

        // Hook every scale-to-fit body to a ResizeObserver and run an initial
        // pass so the embed fits before the user notices.
        const scalingBodies = document.querySelectorAll<HTMLElement>(
          ".diagram-body[data-natural-width]",
        )
        for (const body of scalingBodies) {
          if ((body as any).__scaleInit) continue
          ;(body as any).__scaleInit = true
          const ro = new ResizeObserver(() => scaleEmbed(body))
          ro.observe(body)
          // Initial pass.
          requestAnimationFrame(() => scaleEmbed(body))
        }

        // Render mermaid sources to SVG.
        const mermaidNodes = document.querySelectorAll<HTMLElement>("pre.mermaid")
        if (mermaidNodes.length === 0) return
        try {
          const mermaid = (await import("mermaid")).default
          mermaid.initialize({
            startOnLoad: false,
            theme: "base",
            themeVariables: {
              // Dark palette: black background, white lines and borders.
              background: "#000000",
              primaryColor: "#000000",          // node fill
              primaryTextColor: "#fafafa",      // node text
              primaryBorderColor: "#fafafa",    // node border (white)
              lineColor: "#fafafa",             // edges (white)
              edgeLabelBackground: "#000000",   // edge label background
              secondaryColor: "#000000",
              tertiaryColor: "#000000",
              clusterBkg: "#000000",
              clusterBorder: "#525252",
              labelBoxBkgColor: "#000000",
              labelBoxBorderColor: "#fafafa",
              fontFamily: "Inter Tight, Inter, ui-sans-serif, system-ui",
              fontSize: "13px",
            },
            securityLevel: "loose",
          })
          await mermaid.run({ nodes: Array.from(mermaidNodes) })
        } catch (err) {
          console.error("[mermaid] failed to render:", err)
        }
      }

      // ESC closes any open fullscreen diagram.
      document.addEventListener("keydown", (e) => {
        if (e.key !== "Escape") return
        const open = document.querySelector(".diagram-frame.is-fullscreen")
        if (open) {
          open.classList.remove("is-fullscreen")
          document.body.classList.remove("diagram-overlay-open")
        }
      })

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initDiagrams)
      } else {
        initDiagrams()
      }
      document.addEventListener("astro:page-load", initDiagrams)
    </script>
  </body>
</html>
