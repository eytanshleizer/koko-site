---
import { getCollection } from "astro:content"
import Base from "@/layouts/Base.astro"
import HeroOrb from "@/components/HeroOrb.astro"
import HeroNebula from "@/components/HeroNebula.astro"
import HeroParticles from "@/components/HeroParticles.astro"
import SectionLabel from "@/components/SectionLabel.astro"

const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "")
const link = (href: string) => base + href

const posts = (await getCollection("notebook", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
const recentPosts = posts.slice(0, 3)

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })
---

<Base
  title="Eytan Shleizer"
  description="Problem exploration, AI, and the shape of what's coming. A working notebook by Eytan Shleizer."
>
  <!-- ============================== HERO ============================== -->
  <section class="relative overflow-hidden">
    <!-- Drifting space dust across the entire hero -->
    <HeroParticles />

    <div class="container-page relative z-10 pt-16 pb-28 md:pt-24 md:pb-40">
      <SectionLabel fig="FIG 0.0" title="Index" />

      <div class="mt-10 grid items-center gap-12 md:grid-cols-[1.05fr_1fr]">
        <div class="relative z-10">
          <h1
            class="text-display-xl font-semibold tracking-tightest text-bone-0"
            style="text-wrap: balance;"
          >
            <span class="block">Problem</span>
            <span class="block text-bone-200">solving</span>
            <span class="block">in the age</span>
            <span class="block text-bone-200">of intelligence.</span>
          </h1>

          <p
            class="mt-8 max-w-xl text-[17px] leading-[1.65] text-bone-300 md:text-[18px]"
          >
            <span class="text-bone-0">Eytan Shleizer.</span> A working notebook on the
            problems worth solving — how they emerge, evolve, and resist easy answers.
            Thinking, instruments, and explorations at the edge of AI.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a class="btn-solid" href={link("/notebook")}>
              Read the notebook
              <span aria-hidden="true">→</span>
            </a>
            <a class="btn-ghost" href={link("/tools")}>See the tools</a>
          </div>
        </div>

        <!-- Orb stage (right column on desktop, full-bleed background on mobile) -->
        <div class="relative">
          <HeroNebula />
          <HeroOrb />
        </div>
      </div>
    </div>

  </section>

  <div class="container-page"><div class="hairline"></div></div>

  <!-- ========================== MANIFESTO ========================== -->
  <section class="relative">
    <div class="container-page py-24 md:py-32">
      <SectionLabel fig="FIG 0.1" title="Stance" />
      <p
        class="mt-10 max-w-[58ch] text-[28px] leading-[1.2] tracking-tight text-bone-300 md:text-[40px] md:leading-[1.15]"
        style="text-wrap: balance;"
      >
        <span class="text-bone-0">Most problems worth working on can't be solved.</span>
        They can only be explored, understood, and navigated. The interesting questions
        resist answers — and the cost of being wrong is paid upstream of the work.
      </p>
    </div>
  </section>

  <div class="container-page"><div class="hairline"></div></div>

  <!-- ========================= NAVIGATE ========================= -->
  <section class="relative">
    <div class="container-page py-24 md:py-32">
      <div class="flex items-end justify-between gap-6">
        <div>
          <SectionLabel fig="FIG 0.2" title="Navigate" />
          <h2
            class="mt-4 max-w-2xl text-display-sm font-semibold tracking-tighter text-bone-0"
            style="text-wrap: balance;"
          >
            Three doors into the work.
          </h2>
        </div>
      </div>

      <div class="mt-12 grid gap-px bg-bone-500/15 md:grid-cols-3">
        <!-- Notebook -->
        <a
          class="group block bg-ink-0 p-8 transition hover:bg-ink-50 md:p-10"
          href={link("/notebook")}
        >
          <p class="label-mono">FIG 0.2.1</p>
          <div class="mt-8 mb-10 h-24 w-full">
            <svg
              viewBox="0 0 120 80"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              class="h-full w-auto text-bone-200 transition group-hover:text-bone-0"
              aria-hidden="true"
            >
              <path d="M 8 22 Q 40 10, 70 22 T 112 28" />
              <path d="M 8 40 Q 40 28, 70 40 T 112 46" />
              <path d="M 8 58 Q 40 46, 70 58 T 112 64" />
            </svg>
          </div>
          <h3 class="text-[1.15rem] font-semibold text-bone-0">Notebook</h3>
          <p class="mt-3 text-[14.5px] leading-relaxed text-bone-300">
            Long-form thinking on AI, problem exploration, and futures design. Posts
            are working drafts more than finished essays.
          </p>
          <span class="mt-6 inline-flex items-center gap-1 text-[13px] text-bone-50">
            Read the notebook
            <span class="transition group-hover:translate-x-0.5" aria-hidden="true">→</span>
          </span>
        </a>

        <!-- Tools -->
        <a
          class="group block bg-ink-0 p-8 transition hover:bg-ink-50 md:p-10"
          href={link("/tools")}
        >
          <p class="label-mono">FIG 0.2.2</p>
          <div class="mt-8 mb-10 h-24 w-full">
            <svg
              viewBox="0 0 120 80"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              class="h-full w-auto text-bone-200 transition group-hover:text-bone-0"
              aria-hidden="true"
            >
              <circle cx="60" cy="40" r="26" />
              <line x1="60" y1="6" x2="60" y2="74" />
              <line x1="26" y1="40" x2="94" y2="40" />
              <line x1="36" y1="16" x2="84" y2="64" />
              <line x1="84" y1="16" x2="36" y2="64" />
            </svg>
          </div>
          <h3 class="text-[1.15rem] font-semibold text-bone-0">Tools</h3>
          <p class="mt-3 text-[14.5px] leading-relaxed text-bone-300">
            Skills, prompts, and small instruments that extend how I think and work.
            Each one is sharpened, named, and put back in the case.
          </p>
          <span class="mt-6 inline-flex items-center gap-1 text-[13px] text-bone-50">
            See the tools
            <span class="transition group-hover:translate-x-0.5" aria-hidden="true">→</span>
          </span>
        </a>

        <!-- About -->
        <a
          class="group block bg-ink-0 p-8 transition hover:bg-ink-50 md:p-10"
          href={link("/about")}
        >
          <p class="label-mono">FIG 0.2.3</p>
          <div class="mt-8 mb-10 h-24 w-full">
            <svg
              viewBox="0 0 120 80"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              class="h-full w-auto text-bone-200 transition group-hover:text-bone-0"
              aria-hidden="true"
            >
              <circle cx="60" cy="40" r="32" />
              <circle cx="60" cy="40" r="20" />
              <circle cx="60" cy="40" r="8" fill="currentColor" />
            </svg>
          </div>
          <h3 class="text-[1.15rem] font-semibold text-bone-0">About me</h3>
          <p class="mt-3 text-[14.5px] leading-relaxed text-bone-300">
            Working at the edge of intelligence and intent — what I'm working on,
            who I'd like to talk to, and where to find me.
          </p>
          <span class="mt-6 inline-flex items-center gap-1 text-[13px] text-bone-50">
            About me
            <span class="transition group-hover:translate-x-0.5" aria-hidden="true">→</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <div class="container-page"><div class="hairline"></div></div>

  <!-- ========================= CURRENTS ========================= -->
  <section>
    <div class="container-page py-24 md:py-32">
      <div class="flex items-end justify-between gap-6">
        <div>
          <SectionLabel fig="FIG 0.3" title="Currents" variant="accent" />
          <h2
            class="mt-4 max-w-2xl text-display-sm font-semibold tracking-tighter text-bone-0"
          >
            Latest from the notebook.
          </h2>
        </div>
        <a
          class="hidden md:inline-flex items-center gap-1 text-[13px] text-bone-200 hover:text-bone-0"
          href={link("/notebook")}
        >
          All posts <span aria-hidden="true">→</span>
        </a>
      </div>

      <ul class="mt-10 divide-y divide-bone-500/15 border-t border-bone-500/15">
        {
          recentPosts.map((post) => (
            <li>
              <a
                class="group grid gap-3 py-7 md:grid-cols-[140px_1fr_auto] md:items-baseline md:gap-10"
                href={link(`/notebook/${post.slug}`)}
              >
                <p class="font-mono text-[12px] uppercase tracking-[0.18em] text-bone-300">
                  {fmt(post.data.date)}
                </p>
                <div>
                  <h3 class="text-[18px] font-medium text-bone-0 transition group-hover:text-bone-200 md:text-[20px]">
                    {post.data.title}
                  </h3>
                  <p class="mt-1.5 max-w-[60ch] text-[14px] leading-relaxed text-bone-300">
                    {post.data.excerpt}
                  </p>
                </div>
                <span
                  aria-hidden="true"
                  class="hidden text-bone-300 transition group-hover:translate-x-0.5 group-hover:text-bone-0 md:inline"
                >
                  →
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <div class="container-page"><div class="hairline"></div></div>

  <!-- =========================== CTA =========================== -->
  <section>
    <div class="container-page py-24 md:py-32">
      <div class="grid gap-10 md:grid-cols-[1fr_auto] md:items-end">
        <div>
          <SectionLabel fig="FIG 0.4" title="End matter" />
          <p
            class="mt-6 max-w-[40ch] text-[28px] font-semibold leading-[1.15] tracking-tight text-bone-0 md:text-[36px]"
            style="text-wrap: balance;"
          >
            If a problem won't sit still, it's probably the right one to chase.
          </p>
        </div>
        <div class="flex gap-3">
          <a class="btn-solid" href={link("/about")}
            >About me <span aria-hidden="true">→</span></a
          >
          <a
            class="btn-ghost"
            href="https://github.com/eytanshleizer"
            target="_blank"
            rel="noopener">GitHub</a
          >
        </div>
      </div>
    </div>
  </section>
</Base>
