---
interface Props {
  fig?: string
  title?: string
  variant?: "default" | "accent"
}

const { fig, title, variant = "default" } = Astro.props as Props
const labelClass = variant === "accent" ? "label-mono-accent" : "label-mono"
---

<div class="flex items-center gap-3">
  {fig && <span class={labelClass}>{fig}</span>}
  {fig && title && <span class="h-px w-6 bg-bone-500/30"></span>}
  {title && <span class={labelClass}>{title}</span>}
</div>
