---
// Faint drifting space dust across the hero. Lightweight canvas, no deps.
---

<canvas class="hero-particles" data-hero-particles aria-hidden="true"></canvas>

<style>
  .hero-particles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.7;
  }
</style>

<script>
  // Initialize all hero-particles canvases on the page.
  function init() {
    const canvases = document.querySelectorAll<HTMLCanvasElement>(
      "canvas[data-hero-particles]"
    )
    for (const canvas of canvases) {
      if ((canvas as any)._heroParticlesStarted) continue
      ;(canvas as any)._heroParticlesStarted = true
      const ctx = canvas.getContext("2d")
      if (!ctx) continue

      let w = 0,
        h = 0,
        dpr = 1
      type P = {
        x: number
        y: number
        vx: number
        vy: number
        r: number
        a: number
        hue: number
        twk: number
      }
      const particles: P[] = []

      const fit = () => {
        dpr = Math.min(window.devicePixelRatio || 1, 2)
        const rect = canvas.getBoundingClientRect()
        w = rect.width
        h = rect.height
        canvas.width = Math.floor(w * dpr)
        canvas.height = Math.floor(h * dpr)
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0)
      }

      const seed = () => {
        particles.length = 0
        const target = Math.floor((w * h) / 9000) + 30
        for (let i = 0; i < target; i++) {
          particles.push({
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * 0.04,
            vy: (Math.random() - 0.5) * 0.025 - 0.01,
            r: Math.random() * 1.4 + 0.3,
            a: 0.18 + Math.random() * 0.55,
            hue: 25 + Math.random() * 30, // warm white -> faint amber
            twk: Math.random() * Math.PI * 2,
          })
        }
      }

      fit()
      seed()
      window.addEventListener("resize", () => {
        fit()
        seed()
      })

      let raf = 0
      const tick = (t: number) => {
        ctx.clearRect(0, 0, w, h)
        for (const p of particles) {
          p.x += p.vx
          p.y += p.vy
          if (p.x < -10) p.x = w + 10
          if (p.x > w + 10) p.x = -10
          if (p.y < -10) p.y = h + 10
          if (p.y > h + 10) p.y = -10
          p.twk += 0.012
          const flicker = 0.85 + Math.sin(p.twk) * 0.15
          ctx.beginPath()
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2)
          ctx.fillStyle = `hsla(${p.hue}, 60%, 92%, ${p.a * flicker})`
          ctx.shadowBlur = 6
          ctx.shadowColor = `hsla(${p.hue}, 80%, 80%, ${p.a * 0.6})`
          ctx.fill()
        }
        ctx.shadowBlur = 0
        raf = requestAnimationFrame(tick)
      }
      raf = requestAnimationFrame(tick)

      // Pause when off-screen
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting && !raf) raf = requestAnimationFrame(tick)
            if (!e.isIntersecting && raf) {
              cancelAnimationFrame(raf)
              raf = 0
            }
          }
        },
        { threshold: 0 }
      )
      io.observe(canvas)
    }
  }

  init()
  document.addEventListener("astro:page-load", init)
</script>
