---
import Base from "@/layouts/Base.astro"
import { getCollection } from "astro:content"

const all = await getCollection("tools", ({ data }) => !data.draft)

// Sort: apps first (most interactive), then docs, then links. Within
// each group, newer dates first; entries without a date sink to the end.
const order = { app: 0, doc: 1, link: 2 } as const
const tools = all.sort((a, b) => {
  const k = order[a.data.kind] - order[b.data.kind]
  if (k !== 0) return k
  const da = a.data.date?.getTime() ?? 0
  const db = b.data.date?.getTime() ?? 0
  return db - da
})

const allTags = Array.from(new Set(tools.flatMap((t) => t.data.tags))).sort()

const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "")
const link = (href: string) => base + href

const kindLabel = (k: "app" | "doc" | "link") =>
  k === "app" ? "Application" : k === "doc" ? "Skill / Doc" : "Link ↗"
---

<Base
  title="Tools · Eytan Shleizer"
  description="Skills, apps, and small instruments that extend how I think and work."
>
  <section>
    <div class="container-page pt-16 pb-10 md:pt-24 md:pb-14">
      <h1
        class="max-w-3xl text-display font-semibold tracking-tighter text-bone-0"
        style="text-wrap: balance;"
      >
        Instruments for thinking, sharpened and named.
      </h1>
      <p class="mt-6 max-w-2xl text-[17px] leading-[1.65] text-bone-300 md:text-[18px]">
        Each one is built for a specific shape of problem — Claude skills,
        small apps, prompt patterns. Open, copy, or read.
      </p>
      {
        allTags.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-2">
            {allTags.map((t) => (
              <span class="rounded-full border border-bone-500/25 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.15em] text-bone-300">
                {t}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <div class="container-page"><div class="hairline"></div></div>

  <section>
    <div class="container-page py-14 md:py-20">
      {
        tools.length === 0 ? (
          <p class="max-w-prose text-[15px] leading-relaxed text-bone-300">
            No tools yet. Run <code class="font-mono text-bone-100">npm run sync-tools</code> to pull from the iCloud Tools folder.
          </p>
        ) : (
          <ul class="divide-y divide-bone-500/15 border-b border-bone-500/15">
            {tools.map((t) => {
              const isExternal = t.data.kind === "link"
              const href = isExternal
                ? (t.data.url as string)
                : link(`/tools/${t.id}`)
              return (
                <li>
                  <a
                    href={href}
                    target={isExternal ? "_blank" : undefined}
                    rel={isExternal ? "noopener" : undefined}
                    class="block py-8 transition hover:bg-bone-0/[0.02]"
                  >
                    <div class="grid gap-4 md:grid-cols-[140px_1fr_auto] md:items-baseline md:gap-10">
                      <p class="font-mono text-[12px] uppercase tracking-[0.18em] text-bone-300">
                        {kindLabel(t.data.kind)}
                      </p>
                      <div>
                        <h2 class="text-[22px] font-semibold tracking-tight text-bone-0 md:text-[26px]">
                          {t.data.title}
                        </h2>
                        {t.data.excerpt && (
                          <p class="mt-2 max-w-[60ch] text-[14.5px] leading-relaxed text-bone-300">
                            {t.data.excerpt}
                          </p>
                        )}
                        {t.data.tags.length > 0 && (
                          <div class="mt-3 flex flex-wrap gap-1.5">
                            {t.data.tags.map((tag) => (
                              <span class="rounded-full bg-bone-0/[0.06] px-2.5 py-0.5 font-mono text-[10.5px] uppercase tracking-[0.12em] text-bone-200">
                                {tag}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                      <span aria-hidden="true" class="hidden text-bone-300 md:inline">
                        →
                      </span>
                    </div>
                  </a>
                </li>
              )
            })}
          </ul>
        )
      }

      <p class="mt-10 max-w-prose text-[14.5px] leading-relaxed text-bone-300">
        More instruments are in the workshop. If you want to use one or
        collaborate on building something specific,{" "}
        <a
          class="text-bone-0 underline underline-offset-4 decoration-bone-500/40 hover:decoration-bone-200"
          href={link("/contact")}
        >
          get in touch
        </a>.
      </p>
    </div>
  </section>
</Base>
