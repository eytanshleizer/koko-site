---
const links = [
  { label: "Home", href: "/" },
  { label: "Notebook", href: "/notebook" },
  { label: "Tools", href: "/tools" },
  { label: "Ideas", href: "/ideas" },
  { label: "About", href: "/about" },
]

const path = Astro.url.pathname.replace(/\/$/, "") || "/"
const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "")

const withBase = (href: string) => {
  if (href === "/") return base + "/"
  return base + href
}

const isActive = (href: string) => {
  if (href === "/") return path === "/" || path === base || path === ""
  return path === withBase(href).replace(/\/$/, "") || path.startsWith(withBase(href) + "/")
}
---

<header class="sticky top-0 z-50 border-b border-bone-500/10 bg-ink-0/95">
  <div class="flex h-14 w-full items-center justify-between px-6 md:px-10">
    <a
      href={withBase("/")}
      class="group flex items-center gap-2.5 text-bone-0"
      aria-label="Home"
    >
      <span class="grid h-6 w-6 place-items-center">
        <span
          class="h-2.5 w-2.5 rounded-full bg-gradient-to-br from-bone-50 to-ember-300 shadow-[0_0_18px_rgba(255,138,76,0.45)]"
        ></span>
      </span>
      <span class="text-[15px] font-semibold tracking-tight">Eytan Shleizer</span>
    </a>

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          links.map((l) => (
            <li>
              <a
                href={withBase(l.href)}
                class:list={[
                  "rounded-full px-3.5 py-1.5 text-[13.5px] transition",
                  isActive(l.href)
                    ? "bg-bone-0/[0.06] text-bone-0"
                    : "text-bone-200 hover:text-bone-0",
                ]}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      href={withBase("/contact")}
      class="hidden md:inline-flex items-center gap-1.5 rounded-full border border-bone-500/25 px-3.5 py-1.5 text-[13px] text-bone-50 transition hover:border-bone-200/40"
    >
      Get in touch
      <span aria-hidden="true">→</span>
    </a>

    <details class="md:hidden">
      <summary class="list-none cursor-pointer p-2 text-bone-200">
        <span class="block h-px w-5 bg-current"></span>
        <span class="mt-1 block h-px w-5 bg-current"></span>
        <span class="mt-1 block h-px w-5 bg-current"></span>
      </summary>
      <div
        class="absolute left-0 right-0 top-14 border-b border-bone-500/15 bg-ink-0/95"
      >
        <ul class="container-page flex flex-col gap-1 py-4">
          {
            links.map((l) => (
              <li>
                <a
                  href={withBase(l.href)}
                  class:list={[
                    "block rounded-md px-3 py-2 text-sm",
                    isActive(l.href)
                      ? "bg-bone-0/[0.06] text-bone-0"
                      : "text-bone-200 hover:text-bone-0",
                  ]}
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </details>
  </div>
</header>
