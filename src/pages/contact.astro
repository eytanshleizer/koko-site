---
import Base from "@/layouts/Base.astro"
---

<Base
  title="Get in touch · Eytan Shleizer"
  description="Email and LinkedIn for Eytan Shleizer."
>
  <section>
    <div class="container-page pt-16 pb-10 md:pt-24 md:pb-14">
      <h1
        class="max-w-3xl text-display font-semibold tracking-tighter text-bone-0"
        style="text-wrap: balance;"
      >
        Get in touch.
      </h1>
    </div>
  </section>

  <div class="container-page"><div class="hairline"></div></div>

  <section>
    <div class="container-page py-14 md:py-20">
      <ul class="space-y-6 text-[18px] leading-[1.6] text-bone-100">
        <li>
          <p class="label-mono text-bone-300">Email</p>
          <a
            class="mt-2 inline-block text-bone-0 underline underline-offset-4 decoration-bone-500/40 hover:decoration-bone-200"
            href="mailto:eytanshleizer@gmail.com"
          >
            eytanshleizer@gmail.com
          </a>
        </li>
        <li>
          <p class="label-mono text-bone-300">LinkedIn</p>
          <a
            class="mt-2 inline-block text-bone-0 underline underline-offset-4 decoration-bone-500/40 hover:decoration-bone-200"
            href="https://linkedin.com/in/eytanshleizer"
            target="_blank"
            rel="noopener"
          >
            linkedin.com/in/eytanshleizer
          </a>
        </li>
      </ul>
    </div>
  </section>
</Base>
