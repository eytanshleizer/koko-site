---
// Generic frame for diagrams, embeds, and interactive demos.
//
// Layout:
//   ┌──────────────────────────────────────────────────┐
//   │  TITLE                                       ⤢   │  ← topbar (thin)
//   ├──────────────────────────────────────────────────┤
//   │                                                  │
//   │            preview (no padding)                  │
//   │                                                  │
//   └──────────────────────────────────────────────────┘
//
// Click ⤢ → the body is *moved* into a fixed-position overlay with its own
// topbar + X close button. Width fills the viewport; if the embed's natural
// height exceeds it, the overlay scrolls vertically. ESC, X, or click on the
// dimmed margin closes.
//
// The scale-to-fit logic in Base.astro re-runs after move so the embed
// scales up cleanly inside the overlay.
//
// Usage:
//   <Diagram title="Problem inbox" naturalWidth={920}>
//     <ProblemIntelApp />
//   </Diagram>
interface Props {
  title?: string
  naturalWidth?: number
}
const { title, naturalWidth } = Astro.props as Props
const bodyAttrs = naturalWidth
  ? { "data-natural-width": String(naturalWidth) }
  : {}
---

<figure class="diagram-frame not-prose">
  <header class="diagram-topbar">
    <span class="diagram-title">{title || ""}</span>
    <button
      type="button"
      class="diagram-action"
      data-diagram-action="open"
      aria-label="Open fullscreen"
    >
      <svg
        viewBox="0 0 16 16"
        width="13"
        height="13"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M2 6V2h4M14 6V2h-4M2 10v4h4M14 10v4h-4" />
      </svg>
    </button>
  </header>
  <div class="diagram-body" {...bodyAttrs}>
    <slot />
  </div>
</figure>
