---
import Base from "@/layouts/Base.astro"
import SectionLabel from "@/components/SectionLabel.astro"

const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "")
const link = (href: string) => base + href

const tools = [
  {
    fig: "FIG 2.1",
    title: "Problem Cartographer",
    excerpt:
      "A Claude skill that turns vague problem statements into a navigable map of terrain, edges, and unknowns.",
    status: "In use",
  },
  {
    fig: "FIG 2.2",
    title: "Notebook Compiler",
    excerpt:
      "A small pipeline that pulls working notes from a folder, classifies their state, and surfaces the ones ready to publish.",
    status: "In use",
  },
  {
    fig: "FIG 2.3",
    title: "Attention Loop",
    excerpt:
      "Tooling for compressing the review-and-redirect cycle when working with agents — small UI, big leverage.",
    status: "In progress",
  },
]
---

<Base
  title="Tools · Eytan Shleizer"
  description="Skills, prompts, and small instruments that extend how I think and work."
>
  <section>
    <div class="container-page pt-16 pb-10 md:pt-24 md:pb-14">
      <SectionLabel fig="FIG 2.0" title="Tools" />
      <h1
        class="mt-6 max-w-3xl text-display font-semibold tracking-tighter text-bone-0"
        style="text-wrap: balance;"
      >
        Instruments for thinking, sharpened and named.
      </h1>
      <p class="mt-6 max-w-2xl text-[17px] leading-[1.65] text-bone-300 md:text-[18px]">
        Each one is built for a specific shape of problem — Claude skills,
        prompt patterns, small pipelines. Sharpened, used, and put back in
        the case.
      </p>
    </div>
  </section>

  <div class="container-page"><div class="hairline"></div></div>

  <section>
    <div class="container-page py-14 md:py-20">
      <ul class="divide-y divide-bone-500/15 border-b border-bone-500/15">
        {
          tools.map((t) => (
            <li>
              <div class="grid gap-4 py-8 md:grid-cols-[160px_1fr_auto] md:items-baseline md:gap-10">
                <div class="flex items-baseline gap-3 md:flex-col md:items-start md:gap-1">
                  <p class="label-mono">{t.fig}</p>
                  <p class="text-[12.5px] text-bone-300">{t.status}</p>
                </div>
                <div>
                  <h2 class="text-[22px] font-semibold tracking-tight text-bone-0 md:text-[26px]">
                    {t.title}
                  </h2>
                  <p class="mt-2 max-w-[60ch] text-[14.5px] leading-relaxed text-bone-300">
                    {t.excerpt}
                  </p>
                </div>
                <span aria-hidden="true" class="hidden text-bone-300 md:inline">
                  ·
                </span>
              </div>
            </li>
          ))
        }
      </ul>

      <p class="mt-10 max-w-prose text-[14.5px] leading-relaxed text-bone-300">
        More instruments are in the workshop. If you want to use one or
        collaborate on building something specific,{" "}
        <a
          class="text-bone-0 underline underline-offset-4 decoration-bone-500/40 hover:decoration-bone-200"
          href={link("/about")}
        >
          get in touch
        </a>.
      </p>
    </div>
  </section>
</Base>
