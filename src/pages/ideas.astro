---
import Base from "@/layouts/Base.astro"

const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "")
const link = (href: string) => base + href
---

<Base
  title="Ideas · Eytan Shleizer"
  description="A working map of the concepts in this notebook — how they connect, build on each other, and pull in new directions."
>
  <section>
    <div class="container-page pt-16 pb-10 md:pt-24 md:pb-14">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-ember-300/60 bg-ember-300/[0.06] px-3 py-1 font-mono text-[11px] uppercase tracking-[0.18em] text-ember-300"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-ember-300"></span>
        Work in progress
      </span>
      <h1
        class="mt-6 max-w-3xl text-display font-semibold tracking-tighter text-bone-0"
        style="text-wrap: balance;"
      >
        A map of the ideas, not just the writing.
      </h1>
      <p class="mt-6 max-w-2xl text-[17px] leading-[1.65] text-bone-300 md:text-[18px]">
        The notebook is the trail; this is the terrain. A working graph of how
        the concepts connect — what builds on what, and where new threads start.
      </p>
    </div>
  </section>

  <div class="container-page"><div class="hairline"></div></div>

  <section>
    <div class="container-page py-24 md:py-32">
      <div class="mx-auto max-w-2xl text-center">
        <!-- Placeholder graph illustration — three clusters of connected nodes -->
        <svg
          viewBox="0 0 320 200"
          fill="none"
          stroke="currentColor"
          class="mx-auto h-48 w-auto text-bone-300"
          aria-hidden="true"
        >
          <line x1="60" y1="60" x2="140" y2="100" stroke-width="0.8" />
          <line x1="60" y1="60" x2="100" y2="140" stroke-width="0.8" />
          <line x1="100" y1="140" x2="180" y2="160" stroke-width="0.8" />
          <line x1="140" y1="100" x2="220" y2="80" stroke-width="0.8" />
          <line x1="220" y1="80" x2="270" y2="130" stroke-width="0.8" />
          <line x1="180" y1="160" x2="270" y2="130" stroke-width="0.8" />
          <line x1="140" y1="100" x2="180" y2="160" stroke-width="0.8" />
          <circle cx="60" cy="60" r="6" fill="currentColor" />
          <circle cx="140" cy="100" r="9" fill="currentColor" />
          <circle cx="100" cy="140" r="5" fill="currentColor" />
          <circle cx="220" cy="80" r="7" fill="currentColor" />
          <circle cx="180" cy="160" r="4" fill="currentColor" />
          <circle cx="270" cy="130" r="6" fill="currentColor" />
        </svg>

        <p class="mt-12 font-mono text-[12px] uppercase tracking-[0.18em] text-bone-300">
          In progress
        </p>
        <p class="mt-4 text-[16.5px] leading-[1.65] text-bone-200">
          The interactive graph view is being built. It will let you wander the
          concepts in this notebook the way they actually live in the head —
          connected, partial, and re-routable.
        </p>
        <a
          class="mt-8 inline-flex items-center gap-1 text-[13px] text-bone-0 underline underline-offset-4 decoration-bone-500/40 hover:decoration-bone-200"
          href={link("/notebook")}
        >
          Read the notebook in the meantime
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</Base>
