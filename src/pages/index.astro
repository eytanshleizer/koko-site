---
// Homepage — composed from section files in src/components/home/.
// The narrative arc (in order):
//   1. Hero            — the opening note
//   2. WhyThisExists   — the personal arrival
//   3. Questions       — the map of the inquiry
//   4. Bet             — the thesis (the missing beat)
//   5. Arc             — placeholder; framework still being drawn
//   6. Interlude       — editorial break (visually distinct)
//   7. Work            — the three doors
//   8. Currents        — proof of life (latest posts)
//   9. Closing         — the invitation

import Base from "@/layouts/Base.astro"

import Hero from "@/components/home/Hero.astro"
import WhyThisExists from "@/components/home/WhyThisExists.astro"
import Questions from "@/components/home/Questions.astro"
import Bet from "@/components/home/Bet.astro"
import Arc from "@/components/home/Arc.astro"
import Interlude from "@/components/home/Interlude.astro"
import Work from "@/components/home/Work.astro"
import Currents from "@/components/home/Currents.astro"
import Closing from "@/components/home/Closing.astro"

const Hairline = () => null
---

<Base
  title="Eytan Shleizer"
  description="Problem solving in the age of intelligence — a working notebook on how humans and AI find, frame, and solve the problems worth solving."
>
  <Hero />
  <div class="container-page"><div class="hairline"></div></div>

  <WhyThisExists />
  <div class="container-page"><div class="hairline"></div></div>

  <Questions />
  <div class="container-page"><div class="hairline"></div></div>

  <Bet />
  <div class="container-page"><div class="hairline"></div></div>

  <Arc />
  {/* Interlude has its own borders — no extra hairline before/after. */}

  <Interlude />

  <Work />
  <div class="container-page"><div class="hairline"></div></div>

  <Currents />
  <div class="container-page"><div class="hairline"></div></div>

  <Closing />
</Base>
