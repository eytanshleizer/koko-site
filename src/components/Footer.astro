---
const year = new Date().getFullYear()
const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "")
const link = (href: string) => (href === "/" ? base + "/" : base + href)
---

<footer class="mt-32 border-t border-bone-500/10">
  <div class="container-page py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-2.5">
          <span
            class="h-2.5 w-2.5 rounded-full bg-gradient-to-br from-bone-50 to-ember-300 shadow-[0_0_14px_rgba(255,138,76,0.4)]"
          ></span>
          <span class="text-[15px] font-semibold tracking-tight">Eytan Shleizer</span>
        </div>
        <p class="mt-4 max-w-sm text-[14px] leading-relaxed text-bone-300">
          Problem exploration. AI. Futures design. A working notebook for the shape of
          what's coming.
        </p>
      </div>

      <div>
        <p class="label-mono">Site</p>
        <ul class="mt-3 space-y-2 text-[14px] text-bone-200">
          <li><a class="hover:text-bone-0" href={link("/notebook")}>Notebook</a></li>
          <li><a class="hover:text-bone-0" href={link("/tools")}>Tools</a></li>
          <li><a class="hover:text-bone-0" href={link("/ideas")}>Ideas</a></li>
          <li><a class="hover:text-bone-0" href={link("/about")}>About</a></li>
        </ul>
      </div>

      <div>
        <p class="label-mono">Elsewhere</p>
        <ul class="mt-3 space-y-2 text-[14px] text-bone-200">
          <li>
            <a
              class="hover:text-bone-0"
              href="https://github.com/eytanshleizer"
              target="_blank"
              rel="noopener">GitHub</a
            >
          </li>
          <li>
            <a
              class="hover:text-bone-0"
              href="https://linkedin.com/in/eytanshleizer"
              target="_blank"
              rel="noopener">LinkedIn</a
            >
          </li>
        </ul>
      </div>

      <div>
        <p class="label-mono">Subscribe</p>
        <p class="mt-3 text-[14px] text-bone-300">
          Occasional dispatches when there is something worth reading.
        </p>
        <a class="btn-ghost mt-4 text-[13px]" href={link("/notebook/feed.xml")}>
          RSS feed
        </a>
      </div>
    </div>

    <div
      class="mt-14 flex flex-col items-start justify-between gap-3 border-t border-bone-500/10 pt-6 text-[12px] text-bone-300 md:flex-row md:items-center"
    >
      <p>© {year} Eytan Shleizer. All rights reserved.</p>
      <p class="font-mono uppercase tracking-[0.18em] text-bone-300">
        v2 · built in the open
      </p>
    </div>
  </div>
</footer>
