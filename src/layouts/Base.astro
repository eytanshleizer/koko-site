---
import "@/styles/global.css"
import Nav from "@/components/Nav.astro"
import Footer from "@/components/Footer.astro"

interface Props {
  title?: string
  description?: string
  ogImage?: string
  // Granular chrome control. /ideas keeps the top Nav for site
  // navigation but drops the Footer to give the graph the full canvas.
  nav?: boolean
  footer?: boolean
}

const {
  title = "Eytan Shleizer",
  description = "Problem exploration, AI, and the shape of what's coming.",
  ogImage,
  nav = true,
  footer = true,
} = Astro.props as Props

const fullTitle = title === "Eytan Shleizer" ? title : `${title} — Eytan Shleizer`
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="bg-ink-0 text-bone-0 antialiased">
    {nav && <Nav />}
    <main>
      <slot />
    </main>
    {footer && <Footer />}

    <!--
      Diagrams (mermaid + the generic <Diagram> component) are wrapped in a
      .diagram-frame with a fullscreen toggle. This script handles two things:
        1. Render mermaid source into SVG with a dark theme (black bg, white
           lines, white borders).
        2. Wire the .diagram-fullscreen buttons so clicking them toggles
           is-fullscreen on the parent .diagram-frame. ESC closes.
      Both run on initial load AND after Astro view-transitions.
    -->
    <script>
      // Scale-to-fit logic for HTML embeds with a fixed design width.
      // The embed's root element declares its width via
      // `data-embed-natural-width="N"`. We size the embed at N px, measure
      // its natural height at that width, then transform-scale it to fit
      // the body's container width. Body height is set to the scaled
      // height. SVG-based embeds (mermaid, D3) don't need this — they
      // scale naturally via viewBox + width:100%/height:100%.
      const scaleEmbed = (body: HTMLElement) => {
        const child = body.firstElementChild as HTMLElement | null
        if (!child) return
        const nw = parseFloat(
          child.getAttribute("data-embed-natural-width") || "",
        )
        if (!nw) return

        child.style.width = nw + "px"
        child.style.flexShrink = "0"
        child.style.transformOrigin = "top left"
        child.style.transform = "none"
        const nh = child.offsetHeight

        const cw = body.clientWidth
        const scale = cw / nw // allow upscaling in fullscreen
        child.style.transform = `scale(${scale})`
        body.style.height = nh * scale + "px"
      }

      // ────────── Fullscreen overlay ──────────
      // We *move* the .diagram-body element into the overlay (and back on
      // close) so the embed's DOM and any running JS state survives the
      // transition. The original spot gets a placeholder div.
      let activeFrame: HTMLElement | null = null
      let activePlaceholder: HTMLElement | null = null

      const openOverlay = (frame: HTMLElement) => {
        if (activeFrame) closeOverlay() // only one at a time
        const body = frame.querySelector<HTMLElement>(".diagram-body")
        if (!body) return
        const titleText =
          frame.querySelector<HTMLElement>(".diagram-title")?.textContent || ""

        // Build overlay
        const overlay = document.createElement("div")
        overlay.className = "diagram-overlay"
        overlay.innerHTML = `
          <header class="diagram-overlay-topbar">
            <span class="diagram-overlay-title"></span>
            <button type="button" class="diagram-action" data-diagram-action="close" aria-label="Close fullscreen">
              <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 3l10 10M13 3L3 13"/>
              </svg>
            </button>
          </header>
          <div class="diagram-overlay-content"></div>
        `
        ;(overlay.querySelector(
          ".diagram-overlay-title",
        ) as HTMLElement).textContent = titleText
        const content = overlay.querySelector(
          ".diagram-overlay-content",
        ) as HTMLElement

        // Swap body for placeholder, move body to overlay
        const placeholder = document.createElement("div")
        placeholder.style.display = "none"
        body.replaceWith(placeholder)
        content.appendChild(body)
        document.body.appendChild(overlay)
        document.body.classList.add("diagram-overlay-open")

        // Wire close handlers
        overlay
          .querySelector("[data-diagram-action='close']")
          ?.addEventListener("click", closeOverlay)
        // Click on dimmed margin (outside content area) closes too — the
        // overlay-content is the visible "sheet"; a click on the bare
        // overlay (not the content) closes.
        overlay.addEventListener("click", (e) => {
          if (e.target === overlay) closeOverlay()
        })

        activeFrame = frame
        activePlaceholder = placeholder

        // Re-scale to fill the new (wider) container.
        requestAnimationFrame(() => scaleEmbed(body))
      }

      const closeOverlay = () => {
        if (!activeFrame || !activePlaceholder) return
        const overlay = document.querySelector<HTMLElement>(".diagram-overlay")
        const body = overlay?.querySelector<HTMLElement>(".diagram-body")
        if (body) activePlaceholder.replaceWith(body)
        overlay?.remove()
        document.body.classList.remove("diagram-overlay-open")
        const f = activeFrame
        activeFrame = null
        activePlaceholder = null
        // Re-scale for original (narrower) container.
        if (body) requestAnimationFrame(() => scaleEmbed(body))
      }

      // Hook a single body to a ResizeObserver + initial scale pass.
      // Idempotent — safe to call repeatedly.
      const wireScaling = (body: HTMLElement) => {
        if ((body as any).__scaleInit) return
        ;(body as any).__scaleInit = true
        const ro = new ResizeObserver(() => scaleEmbed(body))
        ro.observe(body)
        requestAnimationFrame(() => scaleEmbed(body))
      }

      const initDiagrams = async () => {
        // Hook every body whose first child declares a natural width to a
        // ResizeObserver. Embeds without the attribute use the default
        // 16/9 fill behavior (CSS only, no JS).
        const scalingBodies = Array.from(
          document.querySelectorAll<HTMLElement>(".diagram-body"),
        ).filter(
          (b) =>
            b.firstElementChild instanceof HTMLElement &&
            b.firstElementChild.hasAttribute("data-embed-natural-width"),
        )
        for (const body of scalingBodies) wireScaling(body)

        // Render mermaid sources to SVG.
        const mermaidNodes = document.querySelectorAll<HTMLElement>("pre.mermaid")
        if (mermaidNodes.length === 0) return
        // Stash the source text on each pre BEFORE mermaid replaces it
        // with rendered SVG. /ideas pages render mermaid inside hidden
        // panels — when those panels become visible we need to re-run
        // mermaid against a properly sized container, and the source
        // text would otherwise be gone.
        for (const pre of Array.from(mermaidNodes)) {
          if (!pre.dataset.source) pre.dataset.source = pre.textContent ?? ""
        }
        try {
          const mermaid = (await import("mermaid")).default
          mermaid.initialize({
            startOnLoad: false,
            theme: "base",
            themeVariables: {
              // Dark palette: black background, white lines and borders.
              background: "#000000",
              primaryColor: "#000000",          // node fill
              primaryTextColor: "#fafafa",      // node text
              primaryBorderColor: "#fafafa",    // node border (white)
              lineColor: "#fafafa",             // edges (white)
              edgeLabelBackground: "#000000",   // edge label background
              secondaryColor: "#000000",
              tertiaryColor: "#000000",
              clusterBkg: "#000000",
              clusterBorder: "#525252",
              labelBoxBkgColor: "#000000",
              labelBoxBorderColor: "#fafafa",
              fontFamily: "Inter Tight, Inter, ui-sans-serif, system-ui",
              fontSize: "13px",
            },
            securityLevel: "loose",
          })
          await mermaid.run({ nodes: Array.from(mermaidNodes) })
        } catch (err) {
          console.error("[mermaid] failed to render:", err)
        }
      }

      // ESC closes the active fullscreen overlay.
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && activeFrame) closeOverlay()
      })

      // Delegate the open-fullscreen click. React islands (.jsx embeds
      // mounted with client:only="react") render their .diagram-frame
      // AFTER initDiagrams runs, so direct event binding inside the loop
      // wouldn't see them. Delegation works for any frame, whenever it
      // appears in the DOM.
      document.addEventListener("click", (e) => {
        const target = e.target as Element | null
        const btn = target?.closest<HTMLElement>(
          "[data-diagram-action='open']",
        )
        if (!btn) return
        const frame = btn.closest<HTMLElement>(".diagram-frame")
        if (frame) openOverlay(frame)
      })

      // Watch for late-arriving .diagram-body elements (added when a
      // React island hydrates) and wire their scaling observer when
      // they appear with a natural-width child.
      const wireIfScalable = (body: HTMLElement) => {
        if (
          body.firstElementChild instanceof HTMLElement &&
          body.firstElementChild.hasAttribute("data-embed-natural-width")
        ) {
          wireScaling(body)
        }
      }
      const mo = new MutationObserver((records) => {
        for (const r of records) {
          for (const n of r.addedNodes) {
            if (!(n instanceof HTMLElement)) continue
            if (n.classList?.contains("diagram-body")) {
              wireIfScalable(n)
            } else {
              n.querySelectorAll<HTMLElement>(".diagram-body").forEach(
                wireIfScalable,
              )
            }
          }
        }
      })
      mo.observe(document.body, { childList: true, subtree: true })

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initDiagrams)
      } else {
        initDiagrams()
      }
      document.addEventListener("astro:page-load", initDiagrams)
    </script>
  </body>
</html>
