---
// Generic frame for diagrams, embeds, and interactive demos.
//
// Layout:
//   ┌──────────────────────────────────────────────────┐
//   │  TITLE                                       ⤢   │  ← topbar (thin)
//   ├──────────────────────────────────────────────────┤
//   │                                                  │
//   │            preview (no padding)                  │
//   │                                                  │
//   └──────────────────────────────────────────────────┘
//
// Three height modes (pick one):
//   - default                  → body fits its content (mermaid, plain SVG)
//   - aspectRatio="16/9"        → body has a fixed aspect ratio; child fills it
//                                (good for D3, demos, anything that wants a
//                                 video-like preview tile)
//   - naturalWidth={920}        → body's child is sized to N px wide and then
//                                transform-scaled to fit container width
//                                (good for fixed-design SaaS-style mocks)
//
// Click ⤢ → the body is *moved* into a fixed-position overlay with its own
// topbar + X close. Width fills the viewport; if content is taller, the
// overlay scrolls. ESC, X, or click on the dimmed margin closes.
//
// Usage:
//   <Diagram title="Concept map" aspectRatio="16/9">
//     <ConceptGraph />
//   </Diagram>
//
//   <Diagram title="Problem inbox" naturalWidth={920}>
//     <ProblemIntelApp />
//   </Diagram>
interface Props {
  title?: string
  naturalWidth?: number
  aspectRatio?: string  // CSS aspect-ratio value, e.g. "16/9", "4/3", "1/1"
}
const { title, naturalWidth, aspectRatio } = Astro.props as Props

const bodyAttrs: Record<string, string> = {}
if (naturalWidth) bodyAttrs["data-natural-width"] = String(naturalWidth)
if (aspectRatio) bodyAttrs["data-aspect-ratio"] = aspectRatio
const bodyStyle = aspectRatio ? `aspect-ratio: ${aspectRatio};` : undefined
---

<figure class="diagram-frame not-prose">
  <header class="diagram-topbar">
    <span class="diagram-title">{title || ""}</span>
    <button
      type="button"
      class="diagram-action"
      data-diagram-action="open"
      aria-label="Open fullscreen"
    >
      <svg
        viewBox="0 0 16 16"
        width="13"
        height="13"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M2 6V2h4M14 6V2h-4M2 10v4h4M14 10v4h-4" />
      </svg>
    </button>
  </header>
  <div class="diagram-body" style={bodyStyle} {...bodyAttrs}>
    <slot />
  </div>
</figure>
