---
// 7. The work — the three doors. Notebook / Tools / Graph. These are the
// outputs of the bet stated above. Each door speaks to a different reader.
//
// Icons share a design language: 80×80 viewBox, currentColor stroke at
// width 1.25, no fill (except node dots in Graph). Each is composed of
// the same family of primitives — circles and straight lines — and
// occupies the same visual extent (~60×60 inside the 80×80 box). Cards
// flex-column with mt-auto on the link so all three CTAs sit on the
// same baseline regardless of paragraph length above.
const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "")
const link = (href: string) => base + href
---

<section class="relative">
  <div class="container-page py-24 md:py-32">
    <div class="max-w-3xl">
      <p class="font-mono text-[12px] uppercase tracking-[0.18em] text-bone-300">
        The work
      </p>
      <h2
        class="mt-6 text-display-sm font-semibold tracking-tighter text-bone-0"
        style="text-wrap: balance;"
      >
        Three things have come out of chasing it.
      </h2>
      <p class="mt-6 max-w-[60ch] text-[16px] leading-[1.65] text-bone-300">
        A notebook to think out loud, tools to put the thinking to work, and
        a map of how the ideas connect. They feed each other.
      </p>
    </div>

    <div class="mt-12 grid gap-px bg-bone-500/15 md:grid-cols-3">
      <!-- Notebook — nested squares (concentric frame + rotated inner) -->
      <a
        class="group flex flex-col bg-ink-0 p-8 transition hover:bg-ink-50 md:p-10"
        href={link("/notebook")}
      >
        <div class="mb-10 flex h-24 w-full items-center">
          <svg
            viewBox="0 0 80 80"
            fill="none"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-20 w-20 text-bone-200 transition group-hover:text-bone-0"
            aria-hidden="true"
          >
            <rect x="14" y="14" width="52" height="52" />
            <rect
              x="14"
              y="14"
              width="52"
              height="52"
              transform="rotate(45 40 40)"
            />
          </svg>
        </div>
        <h3 class="text-[1.15rem] font-semibold text-bone-0">Notebook</h3>
        <p class="mt-3 text-[14.5px] leading-relaxed text-bone-300">
          Working notes on the questions above — what problems mean now,
          how to frame them for AI, and where the practice is heading.
        </p>
        <span class="mt-auto pt-6 inline-flex items-center gap-1 text-[13px] text-bone-50">
          Read the notebook
          <span class="transition group-hover:translate-x-0.5" aria-hidden="true">→</span>
        </span>
      </a>

      <!-- Tools — circle with inscribed triangle (instrument abstraction) -->
      <a
        class="group flex flex-col bg-ink-0 p-8 transition hover:bg-ink-50 md:p-10"
        href={link("/tools")}
      >
        <div class="mb-10 flex h-24 w-full items-center">
          <svg
            viewBox="0 0 80 80"
            fill="none"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-20 w-20 text-bone-200 transition group-hover:text-bone-0"
            aria-hidden="true"
          >
            <circle cx="40" cy="40" r="26" />
            <polygon points="40,18 60,53 20,53" />
          </svg>
        </div>
        <h3 class="text-[1.15rem] font-semibold text-bone-0">Tools</h3>
        <p class="mt-3 text-[14.5px] leading-relaxed text-bone-300">
          Methods and instruments for problem work — how to structure problem
          spaces for agents, design problems that solve themselves, and tighten
          the review-and-redirect loop. For you, your agent, or both.
        </p>
        <span class="mt-auto pt-6 inline-flex items-center gap-1 text-[13px] text-bone-50">
          See the tools
          <span class="transition group-hover:translate-x-0.5" aria-hidden="true">→</span>
        </span>
      </a>

      <!-- Graph — triangle of connected nodes (network abstraction) -->
      <a
        class="group flex flex-col bg-ink-0 p-8 transition hover:bg-ink-50 md:p-10"
        href={link("/ideas")}
      >
        <div class="mb-10 flex h-24 w-full items-center">
          <svg
            viewBox="0 0 80 80"
            fill="none"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-20 w-20 text-bone-200 transition group-hover:text-bone-0"
            aria-hidden="true"
          >
            <line x1="40" y1="18" x2="18" y2="58" />
            <line x1="40" y1="18" x2="62" y2="58" />
            <line x1="18" y1="58" x2="62" y2="58" />
            <circle cx="40" cy="18" r="4" fill="currentColor" stroke="none" />
            <circle cx="18" cy="58" r="4" fill="currentColor" stroke="none" />
            <circle cx="62" cy="58" r="4" fill="currentColor" stroke="none" />
          </svg>
        </div>
        <h3 class="text-[1.15rem] font-semibold text-bone-0">Graph</h3>
        <p class="mt-3 text-[14.5px] leading-relaxed text-bone-300">
          A working map of the concepts in this notebook — how they connect,
          build on each other, and pull in new directions. The same questions,
          seen visually.
        </p>
        <span class="mt-auto pt-6 inline-flex items-center gap-1 text-[13px] text-bone-50">
          Open the map
          <span class="transition group-hover:translate-x-0.5" aria-hidden="true">→</span>
        </span>
      </a>
    </div>
  </div>
</section>
